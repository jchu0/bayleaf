# PipeGuard QC-triage knowledge corpus (curated; ADR-0009). origin: contrived.
# One JSON object per line (KnowledgeEntry). Advisory only: no diagnostic, clinical,
# or pathogenicity claims; conservative/hedged language; every entry cites a source.
# Grounded in docs/data/qc_metrics.md. Blank and '#' lines are ignored by the loader.
{"id": "know_barcode_index_mismatch", "category": "provenance", "title": "Barcode / index mismatch vs sample sheet", "keywords": ["barcode", "index", "index2", "sample", "sheet", "samplesheet", "demultiplex", "demultiplexed", "demux", "mismatch", "collision", "chain", "custody", "provenance", "swap", "hopping"], "likely_cause": "A mismatch between the declared sample-sheet index and the demultiplexed index most often indicates a sample-sheet data-entry error, an index swap during library prep or pooling, or index hopping on patterned flow cells. Reads may be attributed to the wrong sample, so chain of custody cannot be assumed intact.", "suggested_action": "Do not release. Reconcile the sample sheet, the barcode/index manifest, and the LIMS record, and confirm the i7/i5 assignment for the affected library before any downstream use. If pooling or index hopping is suspected, review neighboring wells and samples.", "source": "docs/data/qc_metrics.md Gate 1 — barcode/index integrity (ESCALATE)", "tags": ["preflight", "provenance", "escalate"]}
{"id": "know_sample_absent_from_samplesheet", "category": "provenance", "title": "Sample has QC output but no sample-sheet row", "keywords": ["sample", "absent", "missing", "samplesheet", "sheet", "qc", "results", "output", "present", "unregistered", "provenance", "orphan"], "likely_cause": "A sample with QC output but no sample-sheet row commonly reflects a demultiplexing or sample-sheet mismatch, a late-added or renamed library, or an accidental extra output. Its provenance cannot be established from the sheet alone.", "suggested_action": "Trace the sample back to the pooling and LIMS records to establish its origin before release. Correct the sample sheet or re-demultiplex if the row was omitted in error, and confirm no other sample was displaced.", "source": "docs/data/qc_metrics.md Gate 1 — barcode/index integrity; schemas.md provenance invariants", "tags": ["preflight", "provenance", "escalate"]}
{"id": "know_missing_intake_metadata", "category": "metadata", "title": "Missing required intake metadata", "keywords": ["metadata", "intake", "missing", "subject", "tissue", "library", "prep", "submitter", "submitted", "field", "provenance", "traceability", "accessioning"], "likely_cause": "Missing required intake metadata (for example subject, tissue, library prep, or submitter) usually reflects an incomplete accessioning or LIMS handoff rather than a sequencing problem. It blocks downstream traceability but is not itself a quality defect.", "suggested_action": "Recover the missing field(s) from the requisition or LIMS and complete the intake record before release. Prefer holding over failing; the reads may be fine once provenance is restored.", "source": "docs/data/qc_metrics.md Gate 1 — intake; schemas.md Sample metadata", "tags": ["preflight", "metadata", "hold"]}
{"id": "know_low_q30", "category": "qc", "title": "Q30 below the platform expectation", "keywords": ["q30", "quality", "phred", "base", "basecall", "low", "below", "gate", "cycles", "read", "length", "sequencing", "fastp", "overclustering"], "likely_cause": "Q30 below the platform by read-length expectation commonly points to run-level sequencing quality issues: overclustering, reagent or flow-cell degradation, late-cycle quality drop-off, or a read length beyond the kit's rated spec. It tends to be a run or lane signal more than a per-sample one.", "suggested_action": "Compare against the platform's rated %>=Q30 for this read length and check whether neighboring samples and lanes are also low (run-level) versus isolated. Hold for reviewer; if broadly low, discuss a resequencing or rerun decision with the sequencing team.", "source": "docs/data/qc_metrics.md Gate 2 Q30 + platform matrix (Illumina RUO spec, not a clinical gate)", "tags": ["qc", "hold"]}
{"id": "know_low_coverage_depth", "category": "coverage", "title": "Low mean/median coverage depth", "keywords": ["coverage", "depth", "mean", "median", "low", "shallow", "below", "gate", "reads", "yield", "undersequenced", "mosdepth", "modality"], "likely_cause": "Low mean or median coverage relative to the assay target often reflects low library yield, under-loading or under-sequencing, or fewer reads assigned after demultiplexing. Depth is modality-specific (panel, WES, WGS), so interpret it against the assay's configured target rather than a universal number.", "suggested_action": "Confirm the coverage target for this assay and modality, and check read yield and % reads identified upstream. Hold; a top-up sequencing run or a rerun may be warranted if depth is materially short. Report depth and breadth as distinct signals.", "source": "docs/data/qc_metrics.md Gate 2 — mean/median coverage (per-modality)", "tags": ["qc", "coverage", "hold"]}
{"id": "know_low_breadth_target_20x", "category": "coverage", "title": "Low breadth / callable-region gaps despite adequate depth", "keywords": ["breadth", "target", "callable", "20x", "percent", "fraction", "gaps", "reportable", "regions", "uniformity", "dropout", "capture", "coverage", "mosdepth"], "likely_cause": "Adequate mean depth with low breadth (% target >= 20x) or callable-region gaps suggests uneven coverage or capture dropout rather than simple under-sequencing, for example GC bias, capture inefficiency, or localized low-complexity dropout. Mean depth alone can mask gaps in reportable regions.", "suggested_action": "Inspect per-region and per-base coverage to localize the gaps, and distinguish breadth loss from depth loss. Hold and consider orthogonal or Sanger fill for reportable-region gaps rather than a silent pass. This is an advisory coverage observation, not a variant call.", "source": "docs/data/qc_metrics.md Principle 2 (breadth/callability) + Gate 2 breadth >= 20x", "tags": ["qc", "coverage", "hold"]}
{"id": "know_high_duplication", "category": "qc", "title": "Elevated duplication rate", "keywords": ["duplication", "duplicate", "dup", "rate", "percent", "picard", "library", "complexity", "pcr", "optical", "amplicon", "input"], "likely_cause": "An elevated duplication rate frequently indicates low library complexity, over-amplification (too many PCR cycles or low input), or optical duplicates. Expected duplication is assay-dependent: amplicon panels are high by design, while hyb-capture and WES are lower.", "suggested_action": "Interpret against the assay's expected duplication band before acting. If it is unexpectedly high for a hyb or WES library, check input amount and PCR cycles; effective (deduplicated) coverage may be lower than the raw figure. Hold for reviewer.", "source": "docs/data/qc_metrics.md Gate 2 — Picard PERCENT_DUPLICATION (assay-tuned)", "tags": ["qc", "hold"]}
{"id": "know_low_reads_identified_yield", "category": "qc", "title": "Low % reads identified / low yield", "keywords": ["reads", "identified", "percent", "yield", "assigned", "demultiplex", "undetermined", "index", "low", "cluster", "loading", "pooling"], "likely_cause": "A low fraction of reads identified or assigned (a high undetermined fraction) often reflects index-read quality problems, sample-sheet index errors, or uneven pooling rather than a per-sample defect. It can co-occur with reduced usable yield for the affected sample.", "suggested_action": "Check the undetermined-index report and the pooling balance, and verify the i7/i5 assignment for the low sample. Hold; if an index error is confirmed, re-demultiplexing may recover reads without resequencing.", "source": "docs/data/qc_metrics.md Gate 1/2 — yield + % reads identified", "tags": ["qc", "hold"]}
{"id": "know_low_mapping_rate", "category": "qc", "title": "Low % mapped / alignment rate", "keywords": ["mapping", "mapped", "alignment", "flagstat", "percent", "low", "reference", "contamination", "adapter", "unmapped", "saliva", "microbiome"], "likely_cause": "A low % mapped can indicate adapter or quality contamination, the wrong reference build, or non-target content such as microbial DNA. For saliva samples a lower human-mapped % is expected because of oral-microbiome DNA and is not itself cross-sample human contamination.", "suggested_action": "Confirm the reference build and adapter trimming, and check the sample type (saliva loosens the mapping, on-target, and yield gates). If the sample is blood and mapping is low, review for contamination or a prep issue. Hold for reviewer.", "source": "docs/data/qc_metrics.md Gate 2 — % mapped (ROT); Sample type (saliva)", "tags": ["qc", "hold"]}
{"id": "know_contamination_freemix", "category": "contamination", "title": "Elevated cross-sample contamination estimate", "keywords": ["contamination", "freemix", "verifybamid", "verifybamid2", "cross", "sample", "mixture", "snp", "identity", "estimate", "mixup"], "likely_cause": "An elevated cross-sample contamination estimate (VerifyBamID2 FREEMIX) suggests DNA from more than one individual, for example a sample mix-up, index hopping, or wet-lab cross-contamination. This is SNP-based human-to-human contamination and is largely unaffected by microbial (saliva) content.", "suggested_action": "Do not release. Escalate to review chain of custody and pooling. A band around 1.5-3% warrants scrutiny and above roughly 3% is commonly treated as failing per the runbook; correlate with any identity or swap signal. This is an advisory heuristic, not a diagnostic determination.", "source": "docs/data/qc_metrics.md Gate 2 — VerifyBamID2 FREEMIX (band 1.5-3%, >3% fail)", "tags": ["qc", "contamination", "escalate"]}
{"id": "know_sample_swap_identity", "category": "identity", "title": "Sample identity / swap signal", "keywords": ["identity", "swap", "ngscheckmate", "concordance", "concordant", "mismatch", "sex", "fingerprint", "genotype", "match", "tumor", "normal", "pair", "pairing", "mislabel"], "likely_cause": "A sample-identity or swap signal (NGSCheckMate discordance, or a sex-versus-coverage disagreement) suggests a mislabel or a swap between samples, or an incorrect tumor-normal pairing. Genotype fingerprints that should match do not.", "suggested_action": "Do not release. Escalate to reconcile sample labeling and pairing against LIMS, and re-check the fingerprint concordance and the declared sex versus coverage. Treat as a chain-of-custody issue until resolved. Advisory only: a human must confirm the swap.", "source": "docs/data/qc_metrics.md Gate 2 — NGSCheckMate identity/swap (ESCALATE)", "tags": ["qc", "identity", "escalate"]}
{"id": "know_pipeline_step_failure", "category": "pipeline", "title": "Logged pipeline step failure", "keywords": ["pipeline", "failed", "failure", "error", "exit", "code", "crash", "segmentation", "fault", "step", "process", "nextflow", "operational", "filesystem", "network", "rerun"], "likely_cause": "A logged pipeline failure (a nonzero exit, crash, segfault, or error marker) is usually an operational or infrastructure problem such as a transient network or filesystem race, resource exhaustion, or a tool crash, rather than a data-quality defect. Outputs for the sample may be incomplete.", "suggested_action": "Inspect the referenced log lines and the process exit summary. For transient or operational failures the runbook favors a rerun once the cause is cleared; confirm the inputs are intact before requeueing. Escalate only if reruns reproduce the failure.", "source": "docs/data/qc_metrics.md Verdict policy 3 (operational/filesystem failures -> RERUN)", "tags": ["pipeline", "rerun"]}
