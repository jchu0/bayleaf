# PipeGuard node-author tool-card corpus (curated; ADR-0009). origin: contrived.
# One JSON object per line (ToolCardEntry). ADVISORY only: every entry PROPOSES a builder node
# for HUMAN review — a tool name, a pinned version, typed input/output ports, and suggested
# locators. It never runs a tool (compose != execute, ADR-0003) and never sets a verdict
# (ADR-0001). Every port `kind` is grounded in the real builder vocabulary (BTOOLSPEC + GIAB_LOC
# in frontend/src/components/BuilderShared.tsx); a port whose kind is NOT in that vocabulary is a
# documented-but-unregistered slot the loader marks RESERVED (known=false) and the wiring never
# connects. Ports/versions/locators here mirror the per-tool cards in docs/design/builder-cards/.
# Blank and '#' lines are ignored by the loader.
{"id": "tool_fastp", "tool": "fastp", "version": "0.23.4", "stage": "read_qc", "category": "qc", "title": "fastp - adapter/quality trim + read-level QC", "keywords": ["fastp", "trim", "trimming", "adapter", "adapters", "quality", "q30", "read", "reads", "preprocess", "preprocessing", "clip", "filter", "duplication", "fastq"], "inputs": [{"kind": "fastq", "required": true, "role": "data", "note": "raw paired-end reads (-i/-I; R1/R2 collapsed to one typed port)"}, {"kind": "adapter_fasta", "required": false, "role": "reference", "note": "reserved: --adapter_fasta; no registered kind yet"}], "outputs": [{"kind": "fastq", "required": true, "role": "data", "note": "trimmed reads (-o/-O) -> bwa-mem2"}, {"kind": "fastp_json", "required": true, "role": "qc", "note": "-j report -> MultiQC + PipeGuard parse_fastp"}, {"kind": "fastp_html", "required": false, "role": "qc", "note": "-h HTML report (published QC artifact; optional wired port)"}], "locators": [{"kind": "fastq", "field": "glob", "loc": "fastq/*_R{1,2}_001.fastq.gz", "parser": "null", "required": true, "role": "output", "on_multiple": "all"}, {"kind": "fastp_json", "field": "path", "loc": "qc/HG002.fastp.json", "parser": "fastp_json", "required": true, "role": "output", "on_multiple": "error"}], "summary": "Add a fastp 0.23.4 read-QC/trim node at the head of the chain: one fastq input (the raw read pair), a trimmed fastq output to alignment, and a fastp_json QC output that MultiQC aggregates and PipeGuard's parse_fastp reads for Q30/duplication/reads-passing-filter.", "rationale": "fastp is the germline chain's stage-0 preprocessor; its ports trace directly to the real command's flags. The adapter_fasta input is real fastp I/O with no kind in the builder vocabulary yet, so it is proposed as a reserved slot (never auto-wired) rather than invented as a live port; fastp_html is now a registered kind (an optional QC output).", "source": "docs/design/builder-cards/fastp.md; BuilderShared.tsx BTOOLSPEC['fastp']; scripts/run_giab_pipeline.py step_fastp", "tags": ["read_qc", "trim", "qc"]}
{"id": "tool_bwa_mem2", "tool": "bwa-mem2", "version": "2.2.1", "stage": "align", "category": "pipeline", "title": "bwa-mem2 - read alignment to the reference", "keywords": ["bwa", "bwa-mem2", "mem2", "mem", "align", "alignment", "aligner", "map", "mapping", "reference", "genome", "bam", "reads"], "inputs": [{"kind": "fastq", "required": true, "role": "data", "note": "trimmed reads from fastp"}, {"kind": "reference_fasta", "required": true, "role": "reference", "note": "the indexed reference genome"}], "outputs": [{"kind": "bam", "required": true, "role": "data", "note": "aligned reads -> samtools markdup"}], "locators": [{"kind": "bam", "field": "glob", "loc": "align/*.bam", "parser": "null", "required": true, "role": "output", "on_multiple": "error"}], "summary": "Add a bwa-mem2 2.2.1 alignment node: it maps the trimmed fastq onto the reference_fasta and emits a bam stream toward duplicate marking. It has no QC output port - the alignment metrics come from downstream tools.", "rationale": "bwa-mem2 is the alignment stage; fastq + reference_fasta in, bam out, all real vocabulary kinds. The card is deliberately clean on the bottom (QC) edge because alignment itself emits no MultiQC artifact in this chain.", "source": "docs/design/builder-cards/bwa-mem2.md; BuilderShared.tsx BTOOLSPEC['bwa-mem2']; scripts/run_giab_pipeline.py step_align", "tags": ["align", "pipeline"]}
{"id": "tool_samtools_markdup", "tool": "samtools markdup", "version": "1.20", "stage": "markdup", "category": "qc", "title": "samtools markdup - duplicate marking", "keywords": ["samtools", "markdup", "mark", "duplicate", "duplicates", "dedup", "deduplicate", "pcr", "optical", "sort", "fixmate", "index", "bam"], "inputs": [{"kind": "bam", "required": true, "role": "data", "note": "aligned BAM from bwa-mem2"}], "outputs": [{"kind": "bam", "required": true, "role": "data", "note": "dedup BAM -> mosdepth + bcftools call"}, {"kind": "bai", "required": true, "role": "data", "note": "BAM index sidecar"}, {"kind": "markdup_metrics", "required": false, "role": "qc", "note": "-f duplication stats -> MultiQC"}], "locators": [{"kind": "bam", "field": "glob", "loc": "align/*.md.bam", "parser": "null", "required": true, "role": "output", "on_multiple": "error"}, {"kind": "markdup_metrics", "field": "path", "loc": "qc/HG002.markdup.txt", "parser": "markdup_metrics", "required": false, "role": "output", "on_multiple": "error"}], "summary": "Add a samtools markdup 1.20 node (a bundled sort/fixmate/markdup/index stage): one bam input, and bam + bai + markdup_metrics outputs. The dedup bam feeds mosdepth and bcftools call; the markdup_metrics QC file feeds MultiQC.", "rationale": "markdup emits three real vocabulary kinds (bam, bai, markdup_metrics), each traced to the real command's outputs. bai is a required companion because downstream random-access (mosdepth, region-restricted calling) needs an indexed BAM.", "source": "docs/design/builder-cards/samtools-markdup.md; BuilderShared.tsx BTOOLSPEC['samtools markdup']; scripts/run_giab_pipeline.py step_markdup", "tags": ["markdup", "dedup", "qc"]}
{"id": "tool_mosdepth", "tool": "mosdepth", "version": "0.3.8", "stage": "coverage", "category": "coverage", "title": "mosdepth - coverage depth + breadth", "keywords": ["mosdepth", "coverage", "depth", "breadth", "mean", "median", "panel", "region", "thresholds", "bam", "bed"], "inputs": [{"kind": "bam", "required": true, "role": "data", "note": "dedup BAM (positional input)"}, {"kind": "bai", "required": true, "role": "data", "note": "index companion - mosdepth needs an indexed BAM"}, {"kind": "panel_bed", "required": false, "role": "reference", "note": "--by region file (user-defined; required for panel metrics)"}], "outputs": [{"kind": "mosdepth_summary", "required": true, "role": "data", "note": "summary.txt -> MultiQC + run_gate mean coverage"}, {"kind": "mosdepth_thresholds", "required": true, "role": "data", "note": "thresholds.bed.gz -> breadth >=20x/>=30x"}, {"kind": "mosdepth_global_dist", "required": false, "role": "qc", "note": "global.dist.txt coverage distribution (optional QC output)"}, {"kind": "per_base", "required": false, "role": "qc", "note": "reserved: per-base depth (off by --no-per-base); no registered kind yet"}], "locators": [{"kind": "mosdepth_summary", "field": "path", "loc": "mosdepth/HG002.summary.txt", "parser": "mosdepth_summary", "required": true, "role": "output", "on_multiple": "error"}], "summary": "Add a mosdepth 0.3.8 coverage node: it reads the dedup bam (+ its bai and a panel_bed for region mode) and emits mosdepth_summary (mean coverage) and mosdepth_thresholds (breadth at >=20x/>=30x). The per-base ancillary output is a reserved slot, not yet a registered kind.", "rationale": "mosdepth is the coverage-QC leaf; summary + thresholds are real vocabulary kinds that run_gate derives depth/breadth from. per_base is an honest mosdepth output with no kind in the builder vocabulary yet, so it is reserved, never invented as a live wire; the *_dist family are now registered optional kinds.", "source": "docs/design/builder-cards/mosdepth.md; BuilderShared.tsx BTOOLSPEC['mosdepth']; scripts/run_giab_pipeline.py step_mosdepth", "tags": ["coverage", "depth"]}
{"id": "tool_bcftools_call", "tool": "bcftools call", "version": "1.20", "stage": "variant_call", "category": "variant", "title": "bcftools call - variant calling (mpileup | call)", "keywords": ["bcftools", "call", "calling", "variant", "variants", "mpileup", "snp", "indel", "genotype", "pileup", "vcf"], "inputs": [{"kind": "bam", "required": true, "role": "data", "note": "dedup BAM"}, {"kind": "bai", "required": true, "role": "data", "note": "index companion for -R region access"}, {"kind": "reference_fasta", "required": true, "role": "reference", "note": "mpileup -f reference"}, {"kind": "panel_bed", "required": false, "role": "reference", "note": "-R regions restriction (drop for WGS)"}], "outputs": [{"kind": "vcf", "required": true, "role": "data", "note": "raw unnormalized calls.vcf.gz -> bcftools norm"}], "locators": [], "summary": "Add a bcftools call 1.20 node wrapping an 'mpileup | call' pipe as one card: bam + bai + reference_fasta (+ optional panel_bed) in, and a raw vcf out toward normalization. It has no QC/metrics output port - variant-level stats come from a separate bcftools stats node.", "rationale": "bcftools call is the variant-calling stage; all four inputs and the vcf output are real vocabulary kinds. The raw vcf is an intermediate (normalized/filtered downstream), so no run_layout locator is suggested here - inventing one would misrepresent the pipeline.", "source": "docs/design/builder-cards/bcftools-call.md; BuilderShared.tsx BTOOLSPEC['bcftools call']; scripts/run_giab_pipeline.py step_variants", "tags": ["variant_call", "variant"]}
{"id": "tool_bcftools_norm", "tool": "bcftools norm", "version": "1.20", "stage": "filter", "category": "variant", "title": "bcftools norm - left-align / normalize variants", "keywords": ["bcftools", "norm", "normalize", "normalise", "normalization", "left", "align", "decompose", "split", "multiallelic", "filter", "variant", "vcf"], "inputs": [{"kind": "vcf", "required": true, "role": "data", "note": "raw calls from bcftools call"}, {"kind": "reference_fasta", "required": true, "role": "reference", "note": "reference for left-alignment"}], "outputs": [{"kind": "filtered_vcf", "required": true, "role": "data", "note": "gate-ready normalized VCF -> variant gate"}], "locators": [{"kind": "filtered_vcf", "field": "glob", "loc": "variants/*.norm.filtered.vcf.gz", "parser": "vcf", "required": true, "role": "output", "on_multiple": "error"}], "summary": "Add a bcftools norm 1.20 node (the terminal variant-branch node): a raw vcf + reference_fasta in, a normalized filtered_vcf out that becomes the variant gate's input. It left-aligns and normalizes representation so downstream comparisons are honest.", "rationale": "bcftools norm is the filter/normalize stage; vcf + reference_fasta in, filtered_vcf out, all real vocabulary kinds. filtered_vcf is the emitted run_layout locator that the terminal variant gate reads.", "source": "docs/design/builder-cards/bcftools-norm.md; BuilderShared.tsx BTOOLSPEC['bcftools norm']; scripts/run_giab_pipeline.py step_variants", "tags": ["filter", "variant"]}
{"id": "tool_multiqc", "tool": "MultiQC", "version": "1.21", "stage": "qc_aggregate", "category": "qc", "title": "MultiQC - QC aggregation (fan-in)", "keywords": ["multiqc", "aggregate", "aggregation", "aggregator", "report", "reports", "summary", "collate", "qc", "fan", "fanin", "scan", "logs"], "inputs": [{"kind": "fastp_json", "required": true, "role": "qc", "note": "fastp report"}, {"kind": "markdup_metrics", "required": false, "role": "qc", "note": "duplication stats"}, {"kind": "mosdepth_summary", "required": true, "role": "qc", "note": "coverage summary"}, {"kind": "fastqc_zip", "required": false, "role": "qc", "note": "reserved: FastQC module; no registered kind yet"}, {"kind": "bcftools_stats", "required": false, "role": "qc", "note": "reserved: bcftools stats module; no registered kind yet"}, {"kind": "picard_hsmetrics", "required": false, "role": "qc", "note": "reserved: Picard CollectHsMetrics; no registered kind yet"}], "outputs": [{"kind": "multiqc_json", "required": false, "role": "data", "note": "multiqc_data.json -> deterministic ingest -> gate"}, {"kind": "multiqc_html", "required": false, "role": "qc", "note": "reserved: human report; no registered kind yet"}], "locators": [{"kind": "multiqc_json", "field": "path", "loc": "multiqc_data/multiqc_data.json", "parser": "null", "required": false, "role": "output", "on_multiple": "error"}], "summary": "Add a MultiQC 1.21 aggregation node - the terminal QC fan-in: it takes fastp_json + markdup_metrics + mosdepth_summary in and emits multiqc_json for deterministic ingest. Because MultiQC discovers logs by scanning, the card reserves extra input slots (FastQC/bcftools-stats/Picard) for modules an operator may add later.", "rationale": "MultiQC is the QC-aggregate sink; its three wired inputs plus multiqc_json are real vocabulary kinds. The additional module inputs and multiqc_html output are real MultiQC I/O with no builder kind yet, so they are reserved slots - honest capacity for growth, never fabricated live wires.", "source": "docs/design/builder-cards/multiqc.md; BuilderShared.tsx BTOOLSPEC['MultiQC']; data/nf-core-conventions.md", "tags": ["qc_aggregate", "qc"]}
{"id": "tool_ngscheckmate", "tool": "NGSCheckMate", "version": "1.0.1", "stage": "align", "category": "identity", "title": "NGSCheckMate - sample identity / swap check", "keywords": ["ngscheckmate", "identity", "swap", "concordance", "fingerprint", "genotype", "mixup", "mislabel", "sample", "pairing", "custody", "bam"], "inputs": [{"kind": "bam", "required": true, "role": "data", "note": "aligned BAM to fingerprint"}], "outputs": [{"kind": "ngscheckmate", "required": true, "role": "qc", "note": "matched/mismatched concordance report"}], "locators": [], "summary": "Add an NGSCheckMate 1.0.1 identity node: it fingerprints the aligned bam and emits an ngscheckmate concordance report used to flag a sample swap or mislabel for human chain-of-custody reconciliation. It is advisory - it surfaces a signal, it never resolves a swap.", "rationale": "NGSCheckMate is an identity/swap check; bam in and the ngscheckmate report out are both real vocabulary kinds. Resolving a discordance is a human decision, so the node only surfaces the signal - it makes no determination.", "source": "BuilderShared.tsx BTOOLSPEC['NGSCheckMate']; data/nf-core-conventions.md; docs/design/builder-cards/README.md", "tags": ["identity", "align"]}
{"id": "source_reference_fasta", "tool": "Reference FASTA", "version": "GRCh38", "stage": "align", "category": "pipeline", "title": "Reference FASTA - reference genome source", "keywords": ["reference", "genome", "fasta", "grch38", "hg38", "ref", "source"], "inputs": [], "outputs": [{"kind": "reference_fasta", "required": true, "role": "reference", "note": "the reference the aligner/caller/norm consume"}], "locators": [{"kind": "reference_fasta", "field": "path", "loc": "reference/GRCh38.fa", "parser": "null", "required": true, "role": "reference", "on_multiple": "error"}], "summary": "Add a Reference FASTA source node (GRCh38): a no-input source emitting a reference_fasta artifact that bwa-mem2, bcftools call, and bcftools norm consume. Typed wiring keeps a fasta from landing on a fastq port.", "rationale": "A reference source has no inputs and emits one real vocabulary kind (reference_fasta). It anchors the reference bundle the compute nodes read from the top edge.", "source": "BuilderShared.tsx REF_NODES / BTOOLSPEC['Reference FASTA']; docs/design/builder-cards/README.md", "tags": ["reference", "source"]}
{"id": "source_panel_bed", "tool": "Panel BED", "version": "panel", "stage": "coverage", "category": "coverage", "title": "Panel BED - target-region source", "keywords": ["panel", "bed", "region", "regions", "target", "targets", "capture", "interval", "source"], "inputs": [], "outputs": [{"kind": "panel_bed", "required": true, "role": "reference", "note": "target regions for mosdepth --by and bcftools -R"}], "locators": [{"kind": "panel_bed", "field": "path", "loc": "reference/panel.bed", "parser": "null", "required": true, "role": "reference", "on_multiple": "error"}], "summary": "Add a Panel BED source node: a no-input source emitting a panel_bed artifact that mosdepth (--by) and bcftools call (-R) consume to restrict coverage and calling to the target regions.", "rationale": "A panel source has no inputs and emits one real vocabulary kind (panel_bed). It supplies the region restriction the coverage and calling nodes take from the top edge.", "source": "BuilderShared.tsx REF_NODES / BTOOLSPEC['Panel BED']; docs/design/builder-cards/README.md", "tags": ["coverage", "reference", "source"]}
{"id": "source_truth_vcf", "tool": "Truth VCF", "version": "v4.2.1", "stage": "variant_call", "category": "variant", "title": "Truth VCF - GIAB benchmark source", "keywords": ["truth", "benchmark", "giab", "gold", "standard", "hg002", "concordance", "validation", "vcf", "source"], "inputs": [], "outputs": [{"kind": "truth_vcf", "required": false, "role": "reference", "note": "GIAB benchmark VCF for concordance"}], "locators": [{"kind": "truth_vcf", "field": "path", "loc": "reference/HG002_benchmark.vcf.gz", "parser": "null", "required": false, "role": "reference", "on_multiple": "error"}], "summary": "Add a Truth VCF source node (GIAB v4.2.1): a no-input source emitting a truth_vcf artifact for benchmarking a call set against the GIAB gold standard. It grounds any concordance claim in real GIAB truth - it never invents pathogenicity.", "rationale": "A truth source has no inputs and emits one real vocabulary kind (truth_vcf, optional). It anchors variant-concordance work to the GIAB benchmark rather than a fabricated reference.", "source": "BuilderShared.tsx REF_NODES / BTOOLSPEC['Truth VCF']; docs/design/builder-cards/README.md", "tags": ["variant", "reference", "source", "giab"]}
