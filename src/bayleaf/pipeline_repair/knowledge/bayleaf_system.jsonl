# Curated bayleaf SYSTEM-knowledge corpus (RemediationEntry-shaped KnowledgeRecords) for the
# pipeline-repair agent's docs grounding (P3 §2, design/agent-capabilities.md §2). Each entry
# summarizes a real subsystem/ADR so the agent understands the systems involved AND their limits;
# `source` cites the ADR/doc. Not remediation templates (no rule_ids/attach_to) — system context.
{"id": "sys_deterministic_gate", "kind": "system_doc", "category": "bayleaf-system", "title": "The deterministic gate decides; AI only narrates/advises", "keywords": ["verdict", "gate", "deterministic", "rules", "advisory", "agent", "decide"], "summary": "A deterministic rule engine sets every verdict/finding/confidence; agents (triage, repair, archivist, node-author) narrate, suggest, and cite but NEVER set or override a decision.", "rationale": "Limit: any repair proposal is advisory only — it can suggest a fix but cannot change a verdict or apply the fix; a human reviews and acts (ADR-0001).", "source": "docs/adr/ADR-0001-deterministic-gate-advisory-ai.md", "tags": ["invariant", "advisory"]}
{"id": "sys_ai_off_default", "kind": "system_doc", "category": "bayleaf-system", "title": "AI is off by default with a deterministic fallback", "keywords": ["ai", "off", "default", "stub", "fallback", "claude", "offline"], "summary": "Every agent seam is stub-first ($0, offline); a live Claude path turns on per BAYLEAF_*_AGENT=claude and degrades to the deterministic stub on any error or safety refusal.", "rationale": "Limit: with AI off, answers are grounded retrieval, not generated prose — the system stays fully functional and honest without a key (ADR-0006).", "source": "docs/adr/ADR-0006-ai-off-by-default-fallback.md", "tags": ["invariant", "fallback"]}
{"id": "sys_compose_not_execute", "kind": "system_doc", "category": "bayleaf-system", "title": "bayleaf composes pipelines to Nextflow but never executes tools itself", "keywords": ["nextflow", "compile", "compose", "execute", "pipeline", "portability", "driver"], "summary": "The core compiles a card graph to Nextflow (DSL2) text; an external driver runs it. The core never runs a bioinformatics tool — compute portability lives in Nextflow.", "rationale": "Limit: a repair that needs a tool re-run is a proposal for the operator/driver, not something the agent or core executes (compose ≠ execute, ADR-0003).", "source": "docs/adr/ADR-0003-deployment-agnostic-ports.md", "tags": ["invariant", "nextflow"]}
{"id": "sys_provenance_ledger", "kind": "system_doc", "category": "bayleaf-system", "title": "Event-driven core; the ledger is authoritative, the DB a rebuildable projection", "keywords": ["provenance", "event", "ledger", "projection", "database", "audit", "replay"], "summary": "Every I/O is an append-only provenance event; the SQLite/Postgres DB is a rebuildable projection of that ledger (rebuild-db), so history is auditable and replayable.", "rationale": "Limit: recurring-issue history is only as complete as the persisted ledger; an offline demo re-derives from run dirs until rebuild-db populates the projection (ADR-0002).", "source": "docs/adr/ADR-0002-event-driven-core-provenance-ledger.md", "tags": ["provenance", "history"]}
{"id": "sys_qc_metric_catalog", "kind": "system_doc", "category": "bayleaf-system", "title": "QC thresholds are illustrative/configurable, never clinical", "keywords": ["qc", "threshold", "metric", "catalog", "runbook", "gate", "coverage", "q30", "clinical"], "summary": "The metric registry lists a vocabulary; a metric is NOT gated until the runbook adds a threshold. Thresholds are illustrative + operator-configurable, not clinical cutoffs.", "rationale": "Limit: never present a threshold as a clinical standard; a repair that retunes a threshold is a runbook config change, conservative and human-owned.", "source": "docs/data/metric_registry.md", "tags": ["qc", "runbook", "safety"]}
{"id": "sys_agent_taxonomy", "kind": "system_doc", "category": "bayleaf-system", "title": "Advisory agents vs. tool-agents; the action boundary", "keywords": ["agent", "tool-agent", "advisory", "action", "boundary", "monitoring", "auto-retry", "retry"], "summary": "Advisory agents never act. A tool-agent (e.g. the monitoring agent) wired into the graph MAY take bounded operational actions (auto-retry a transient failure) but never touches a verdict/finding/data.", "rationale": "Limit: even an acting agent's remediation is operational (retry/pause/escalate) — decision- or data-bearing changes stay with the gate + human review (ADR-0023).", "source": "docs/adr/ADR-0023-agent-taxonomy-and-action-boundary.md", "tags": ["agents", "invariant"]}
{"id": "sys_scope_by_wiring", "kind": "system_doc", "category": "bayleaf-system", "title": "An agent's file access comes from graph wiring, server-enforced", "keywords": ["scope", "wiring", "access", "binding", "observations", "node", "output", "folder"], "summary": "An agent may read a node's outputs only if it is wired to that node in the run's executed graph; the run's bindings are snapshotted at launch and enforced on the read path.", "rationale": "Limit: an agent can only reason over the tool outputs it is wired to; access never grants authority over a verdict (ADR-0024).", "source": "docs/adr/ADR-0024-scope-by-wiring.md", "tags": ["agents", "access"]}
{"id": "sys_giab_clinvar_truth", "kind": "system_doc", "category": "bayleaf-system", "title": "Clinical variant claims stay grounded in ClinVar/GIAB truth", "keywords": ["variant", "clinvar", "giab", "truth", "pathogenicity", "concordance", "significance"], "summary": "Variant significance is quoted verbatim from ClinVar; benchmarking uses GIAB truth. bayleaf never authors pathogenicity — it reads and cites external annotations.", "rationale": "Limit: a repair touching variant calling must preserve the external annotation/citation; never infer or invent a clinical claim (ADR-0004).", "source": "docs/adr/ADR-0004-vcf-first-giab-substrate.md", "tags": ["variants", "safety"]}
