# Copy to .env and fill in to enable live Claude synthesis.
# The app runs fully offline without any of these (uses the zero-cost stub).

# Required only when PIPEGUARD_SYNTHESIZER=claude
ANTHROPIC_API_KEY=sk-ant-...

# Synthesizer selection: "stub" (default, offline, $0) or "claude" (live API)
PIPEGUARD_SYNTHESIZER=stub

# Model for live synthesis. Default claude-opus-4-8.
# Cheaper options to conserve credits: claude-sonnet-5, claude-haiku-4-5
PIPEGUARD_CLAUDE_MODEL=claude-opus-4-8

# QC-triage agent (advisory; ADR-0009/0012). "stub" (default, offline, $0) or
# "claude" (live API). Falls back to the stub on any error.
PIPEGUARD_TRIAGE_AGENT=stub

# Model for the live triage agent. Defaults to a cheaper tier than synthesis
# (ADR-0012: advisory agents run Sonnet/Haiku). Override for a harder run.
PIPEGUARD_TRIAGE_MODEL=claude-sonnet-5

# Pipeline-repair agent (advisory, agent #2; ADR-0008/0012). "stub" (default, offline, $0)
# or "claude" (live API). Given a recurring issue signature from the monitoring rollup, it
# proposes a HUMAN-REVIEWED pipeline remediation; it never edits a pipeline or sets a verdict.
# Falls back to the stub on any error.
PIPEGUARD_PIPELINE_REPAIR_AGENT=stub

# Model for the live pipeline-repair agent. Defaults to the Opus-high tier (ADR-0012 §3a) —
# this agent reasons over cross-run failure patterns, the hard/rare/high-stakes case the ADR
# reserves the expensive model for (unlike the frequent, cheap triage/feedback agents).
PIPEGUARD_PIPELINE_REPAIR_MODEL=claude-opus-4-8

# Archivist agent (advisory, agent #3; the "librarian" over the data platform; ADR-0012, design
# docs/design/data-platform-and-archivist.md §5). "stub" (default, offline, $0) or "claude" (live
# API). It indexes/summarizes already-decided runs and PROPOSES an archival/organization action +
# an export manifest; it is organizational, never diagnostic — it never sets a verdict, moves a
# file, or relabels an origin. Falls back to the stub on any error.
PIPEGUARD_ARCHIVIST_AGENT=stub

# Model for the live archivist. Defaults to the cheapest tier (ADR-0012): organizing/summarizing
# is a low-stakes task, so it runs Haiku (like the feedback agent), not the Opus narration tier.
PIPEGUARD_ARCHIVIST_MODEL=claude-haiku-4-5-20251001

# Node-authoring agent (advisory, agent #6; T-046). "stub" (default, offline, $0) or "claude" (live
# API). Given a natural-language request for a bioinformatics tool, it proposes a HUMAN-REVIEWED
# builder node (tool name, pinned version, typed ports over the real artifact-kind vocabulary,
# suggested locators); it never runs a tool (compose != execute) or sets a verdict. Unknown port
# kinds are surfaced as reserved slots, never wired. Falls back to the stub on any error.
PIPEGUARD_NODE_AUTHOR_AGENT=stub

# Model for the live node-author agent. Defaults to the mid Sonnet tier (ADR-0012) — authoring one
# node from a described function is moderate composition (like QC-triage), not the cross-run
# reasoning the Opus tier is reserved for. Override for a lighter/heavier run.
PIPEGUARD_NODE_AUTHOR_MODEL=claude-sonnet-5

# Outbound notify port (ADR-0010 §2). "stub" (default, offline, $0 — builds the
# notification payload and records it to an in-memory outbox), or an adapter:
# "slack" | "teams" | "discord". Selecting an adapter does NOT send: each adapter's
# live post is OFF unless its own *_LIVE flag is armed below, so it degrades to the
# stub and never posts. No network is touched by any default.
PIPEGUARD_NOTIFIER=stub

# Arms the outward-facing live Slack post. UNSET/0 (default) = never sends, even with a
# token+channel present. Set to 1 only when you deliberately want to post to a real
# workspace (needs `uv sync --extra slack`). Kept out of the default so a stray token
# can't cause a post.
PIPEGUARD_SLACK_LIVE=

# Target Slack channel id/name for the Slack notify path.
# Never hardcode this — read from env. Example: C0123456789 or "#pipeguard-qc".
# Leave blank offline; a blank resolves to an "unconfigured" placeholder.
PIPEGUARD_SLACK_CHANNEL=

# Slack BOT token (xoxb-…, from OAuth & Permissions → Bot User OAuth Token, scope
# chat:write) for the live send path. Only used when PIPEGUARD_SLACK_LIVE is armed.
# Never commit a real token (this file is the example; put real values in .env).
PIPEGUARD_SLACK_BOT_TOKEN=

# --- Webhook notify adapters (Teams / Discord), T-035 -------------------------------
# Each webhook adapter POSTs via the stdlib (no SDK, no extra dependency) and has its OWN
# live-arm flag, so arming one channel never arms another. Same safety shape as Slack:
# UNSET/0 (default) = never sends; degrades to the offline stub. The webhook URL is a
# SECRET (it embeds an auth token) — env only, never commit a real one, never logged.

# Arms the outward-facing Teams webhook POST. UNSET/0 (default) = never sends, even with a
# URL present. Set to 1 only when you deliberately want to post to a real Teams channel.
PIPEGUARD_TEAMS_LIVE=
# Teams incoming-webhook URL (Channel → Connectors → Incoming Webhook). Only used when
# PIPEGUARD_TEAMS_LIVE is armed. Leave blank offline; a blank resolves to "unconfigured".
PIPEGUARD_TEAMS_WEBHOOK_URL=

# Arms the outward-facing Discord webhook POST. UNSET/0 (default) = never sends, even with
# a URL present. Set to 1 only when you deliberately want to post to a real Discord channel.
PIPEGUARD_DISCORD_LIVE=
# Discord webhook URL (Channel → Edit → Integrations → Webhooks). Only used when
# PIPEGUARD_DISCORD_LIVE is armed. Leave blank offline; a blank resolves to "unconfigured".
PIPEGUARD_DISCORD_WEBHOOK_URL=

# --- Export de-identification seam (T-040 / W14, api/deid.py) ------------------------
# DEMO de-id SEAM, NOT HIPAA de-identification. Salt for pseudonymizing (salted SHA-256,
# non-reversible) the origin-gated intake cohort keys (subject_id/tissue) that the opt-in
# `GET /api/export?include=identity` mode emits for NON-real origins. This is a heuristic
# input, NOT a secret — leave blank to use a documented demo default (keeps the offline
# demo deterministic). Set a per-deployment value to change the pseudonym namespace.
PIPEGUARD_DEID_SALT=

# --- Artifact store (ADR-0003, T-039) -----------------------------------------------
# Where a run's files come from. The store only LOCATES artifacts and stages them to a
# local dir; the deterministic gate reads that dir unchanged and the store never
# influences a verdict (ADR-0001). Same OFF-by-default + degrade-to-local safety shape
# as the notify seam — the demo/tests stay offline on local synthetic/real-giab dirs.

# Adapter selection: "local" (default, offline, zero-dep — fetch is the identity over an
# on-disk run directory) or "s3" (pulls from a bucket, but only when armed below).
PIPEGUARD_ARTIFACT_STORE=local

# Optional base directory for resolving a RELATIVE run reference (e.g. a bare run name).
# Unset (default) = refs are used as-is (a full path). Also the base the S3 store degrades
# to when its live pull is unarmed or fails.
PIPEGUARD_ARTIFACT_LOCAL_ROOT=

# Arms the outward-facing S3 pull. UNSET/0 (default) = never pulls, even with a bucket +
# creds present (degrades to the local store, no network). Set to 1 only when you
# deliberately want to fetch from a real bucket (needs `uv sync --extra s3`). Real
# genomics data on cloud stores is where PHI lives, so this never auto-arms.
PIPEGUARD_S3_LIVE=

# Target S3 bucket for the artifact store (when PIPEGUARD_S3_LIVE is armed). Leave blank
# offline; a blank resolves to an "unconfigured" placeholder that degrades to local.
PIPEGUARD_S3_BUCKET=

# Optional key prefix under the bucket; a run stages from s3://<bucket>/<prefix>/<run_id>/.
# Leave blank to stage from s3://<bucket>/<run_id>/.
PIPEGUARD_S3_PREFIX=

# AWS credentials + region are read by boto3 from the STANDARD environment/instance chain
# (this adapter never reads, holds, or logs them). Set these only when PIPEGUARD_S3_LIVE is
# armed; never commit real values. Example:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# In-app feedback sink (W12). Where POST /api/feedback appends its JSONL product telemetry.
# Optional; default is feedback.events.jsonl at the repo root (gitignored — never commit
# feedback data). An operational path, NOT a secret.
PIPEGUARD_FEEDBACK_PATH=

# --- Postgres port (ADR-0016) — OFF by default; the offline demo uses SQLite/JSONL ----------

# Persistence projection adapter: "sqlite" (default, stdlib, offline) or "postgres" (needs the
# [postgres] extra + DATABASE_URL below). Any failure constructing the Postgres adapter degrades
# to SQLite, so a typo or a down DB never breaks the app.
PIPEGUARD_REPOSITORY=sqlite

# SQLite projection path (when PIPEGUARD_REPOSITORY=sqlite). Blank = in-memory (ephemeral).
PIPEGUARD_DB_PATH=

# Feedback sink backend: "jsonl" (default), "sqlite", or "postgres". The DB options degrade to
# JSONL if unavailable. SQLite feedback DB path (when =sqlite); blank = feedback.sqlite at root.
PIPEGUARD_FEEDBACK_STORE=jsonl
PIPEGUARD_FEEDBACK_DB=

# --- Pipeline Builder save/version store (ADR-0014) — PRODUCT state, OFF the decision gate ---
# Where POST /api/pipelines persists saved builder graphs (a tolerant, versioned envelope). Same
# pluggable shape as the feedback sink: "jsonl" (default), "sqlite", or "postgres"; the DB options
# degrade to JSONL if unavailable. NOT the decision Repository — its own table, never a verdict.
PIPEGUARD_PIPELINE_STORE=jsonl
# JSONL sink path (when =jsonl). Blank = pipeline_graphs.jsonl at the repo root (gitignored —
# never commit saved graphs). An operational path, NOT a secret.
PIPEGUARD_PIPELINE_PATH=
# SQLite pipeline DB path (when =sqlite); blank = pipeline_graphs.sqlite at root. Postgres reuses
# the shared DATABASE_URL below.
PIPEGUARD_PIPELINE_DB=

# --- Review-queue / ticket store (HITL, ADR-0010) — PRODUCT state, OFF the decision gate -----
# Where the review-queue endpoints (POST/GET /api/review/tickets, .../action) persist tickets.
# Same pluggable shape as the feedback/pipeline sinks: "jsonl" (default), "sqlite", or "postgres";
# the DB options degrade to JSONL if unavailable. A ticket is a human-review worklist item — its
# own table, never the decision Repository, never a verdict.
PIPEGUARD_REVIEW_STORE=jsonl
# JSONL sink path (when =jsonl). Blank = review_tickets.jsonl at the repo root (gitignored — never
# commit tickets; they carry operator ids). An operational path, NOT a secret.
PIPEGUARD_REVIEW_PATH=
# SQLite review DB path (when =sqlite); blank = review_tickets.sqlite at root. Postgres reuses the
# shared DATABASE_URL below.
PIPEGUARD_REVIEW_DB=

# --- Settings/config authoring store (T-051, ADR-0017) — PRODUCT state, OFF the decision gate ---
# Where the settings-authoring endpoints (POST/GET /api/settings/thresholds, .../approve) persist
# config-override drafts. Same pluggable shape: "jsonl" (default), "sqlite", or "postgres" (degrade
# to JSONL). A versioned draft->approve override envelope — its own table, never the live runbook.
PIPEGUARD_SETTINGS_STORE=jsonl
# JSONL sink path (when =jsonl). Blank = settings_overrides.jsonl at the repo root (gitignored). An
# operational path, NOT a secret.
PIPEGUARD_SETTINGS_PATH=
# SQLite settings DB path (when =sqlite); blank = settings_overrides.sqlite at root. Postgres reuses
# the shared DATABASE_URL below.
PIPEGUARD_SETTINGS_DB=

# --- Share/report egress audit store (ADR-0018 D3) — PROVENANCE audit, OFF the decision gate -----
# Where POST /api/runs/{id}/share records its DATA_EXPORTED provenance events (get_run merges them
# into a run's trail). Same pluggable shape: "jsonl" (default), "sqlite", or "postgres" (degrade to
# JSONL). Separate from the gate's own EventLedger — a share is a live actor-driven side effect,
# never a verdict. Carries run ids + who exported, so it is local-only, never committed.
PIPEGUARD_SHARE_STORE=jsonl
# JSONL sink path (when =jsonl). Blank = share.events.jsonl at the repo root (gitignored). An
# operational path, NOT a secret.
PIPEGUARD_SHARE_PATH=
# SQLite share DB path (when =sqlite); blank = share.sqlite at root. Postgres reuses the shared
# DATABASE_URL below.
PIPEGUARD_SHARE_DB=

# --- Durable job store (T-131) — execution bookkeeping, OFF the decision gate ---------------------
# Where the intake + Builder-run job registries persist (so a job survives a backend restart; a lost
# 'running' reconciles to complete-if-on-disk else 'lost'). Node-local scratch, so ONLY "jsonl"
# (default) or "sqlite" — no Postgres adapter by design. Degrades to jsonl on any SQLite failure.
# Default sinks live under the gitignored .nf-runs/. Never a verdict; local-only, never committed.
PIPEGUARD_JOB_STORE=jsonl
# JSONL sink path (blank = jobs.events.jsonl under .nf-runs/); SQLite path (blank = jobs.sqlite there).
PIPEGUARD_JOB_PATH=
PIPEGUARD_JOB_DB=

# --- Node-author library store (W2) — accepted authored tool-cards, OFF the decision gate ---------
# Where POST /api/builder/node-proposal/accept persists an accepted (advisory, metadata-only) tool
# card as a draft library entry. Same pluggable shape as the other off-gate stores but node-local:
# "jsonl" (default) or "sqlite" — no Postgres adapter. Degrades to jsonl. Never a script/stub body.
PIPEGUARD_LIBRARY_STORE=jsonl
# JSONL sink path (blank = library.events.jsonl at root, gitignored); SQLite path (blank = at root).
PIPEGUARD_LIBRARY_PATH=
PIPEGUARD_LIBRARY_DB=

# Postgres DSN, used by BOTH the persistence adapter and the Postgres feedback store when armed.
# SECRET — never commit a real value; it carries the DB password. Example (see deploy/postgres/):
# DATABASE_URL=postgresql://pipeguard:pipeguard@localhost:5432/pipeguard
DATABASE_URL=

# Bioconda toolchain bin dir prepended to PATH for the POST /api/runs execution endpoint
# (fastp/bwa-mem2/samtools/mosdepth/bcftools). Without it, submitting a run fails at the driver.
# e.g. /Users/you/miniconda3/envs/hackathon/bin
PIPEGUARD_BIOCONDA_BIN=
