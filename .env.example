# Copy to .env and fill in to enable live Claude synthesis.
# The app runs fully offline without any of these (uses the zero-cost stub).

# Required only when PIPEGUARD_SYNTHESIZER=claude
ANTHROPIC_API_KEY=sk-ant-...

# Synthesizer selection: "stub" (default, offline, $0) or "claude" (live API)
PIPEGUARD_SYNTHESIZER=stub

# Model for live synthesis. Default claude-opus-4-8.
# Cheaper options to conserve credits: claude-sonnet-5, claude-haiku-4-5
PIPEGUARD_CLAUDE_MODEL=claude-opus-4-8

# QC-triage agent (advisory; ADR-0009/0012). "stub" (default, offline, $0) or
# "claude" (live API). Falls back to the stub on any error.
PIPEGUARD_TRIAGE_AGENT=stub

# Model for the live triage agent. Defaults to a cheaper tier than synthesis
# (ADR-0012: advisory agents run Sonnet/Haiku). Override for a harder run.
PIPEGUARD_TRIAGE_MODEL=claude-sonnet-5

# Outbound notify port (ADR-0010 §2). "stub" (default, offline, $0 — builds the
# notification payload and records it to an in-memory outbox), or an adapter:
# "slack" | "teams" | "discord". Selecting an adapter does NOT send: each adapter's
# live post is OFF unless its own *_LIVE flag is armed below, so it degrades to the
# stub and never posts. No network is touched by any default.
PIPEGUARD_NOTIFIER=stub

# Arms the outward-facing live Slack post. UNSET/0 (default) = never sends, even with a
# token+channel present. Set to 1 only when you deliberately want to post to a real
# workspace (needs `uv sync --extra slack`). Kept out of the default so a stray token
# can't cause a post.
PIPEGUARD_SLACK_LIVE=

# Target Slack channel id/name for the Slack notify path.
# Never hardcode this — read from env. Example: C0123456789 or "#pipeguard-qc".
# Leave blank offline; a blank resolves to an "unconfigured" placeholder.
PIPEGUARD_SLACK_CHANNEL=

# Slack BOT token (xoxb-…, from OAuth & Permissions → Bot User OAuth Token, scope
# chat:write) for the live send path. Only used when PIPEGUARD_SLACK_LIVE is armed.
# Never commit a real token (this file is the example; put real values in .env).
PIPEGUARD_SLACK_BOT_TOKEN=

# --- Webhook notify adapters (Teams / Discord), T-035 -------------------------------
# Each webhook adapter POSTs via the stdlib (no SDK, no extra dependency) and has its OWN
# live-arm flag, so arming one channel never arms another. Same safety shape as Slack:
# UNSET/0 (default) = never sends; degrades to the offline stub. The webhook URL is a
# SECRET (it embeds an auth token) — env only, never commit a real one, never logged.

# Arms the outward-facing Teams webhook POST. UNSET/0 (default) = never sends, even with a
# URL present. Set to 1 only when you deliberately want to post to a real Teams channel.
PIPEGUARD_TEAMS_LIVE=
# Teams incoming-webhook URL (Channel → Connectors → Incoming Webhook). Only used when
# PIPEGUARD_TEAMS_LIVE is armed. Leave blank offline; a blank resolves to "unconfigured".
PIPEGUARD_TEAMS_WEBHOOK_URL=

# Arms the outward-facing Discord webhook POST. UNSET/0 (default) = never sends, even with
# a URL present. Set to 1 only when you deliberately want to post to a real Discord channel.
PIPEGUARD_DISCORD_LIVE=
# Discord webhook URL (Channel → Edit → Integrations → Webhooks). Only used when
# PIPEGUARD_DISCORD_LIVE is armed. Leave blank offline; a blank resolves to "unconfigured".
PIPEGUARD_DISCORD_WEBHOOK_URL=

# --- Export de-identification seam (T-040 / W14, api/deid.py) ------------------------
# DEMO de-id SEAM, NOT HIPAA de-identification. Salt for pseudonymizing (salted SHA-256,
# non-reversible) the origin-gated intake cohort keys (subject_id/tissue) that the opt-in
# `GET /api/export?include=identity` mode emits for NON-real origins. This is a heuristic
# input, NOT a secret — leave blank to use a documented demo default (keeps the offline
# demo deterministic). Set a per-deployment value to change the pseudonym namespace.
PIPEGUARD_DEID_SALT=

# --- Artifact store (ADR-0003, T-039) -----------------------------------------------
# Where a run's files come from. The store only LOCATES artifacts and stages them to a
# local dir; the deterministic gate reads that dir unchanged and the store never
# influences a verdict (ADR-0001). Same OFF-by-default + degrade-to-local safety shape
# as the notify seam — the demo/tests stay offline on local synthetic/real-giab dirs.

# Adapter selection: "local" (default, offline, zero-dep — fetch is the identity over an
# on-disk run directory) or "s3" (pulls from a bucket, but only when armed below).
PIPEGUARD_ARTIFACT_STORE=local

# Optional base directory for resolving a RELATIVE run reference (e.g. a bare run name).
# Unset (default) = refs are used as-is (a full path). Also the base the S3 store degrades
# to when its live pull is unarmed or fails.
PIPEGUARD_ARTIFACT_LOCAL_ROOT=

# Arms the outward-facing S3 pull. UNSET/0 (default) = never pulls, even with a bucket +
# creds present (degrades to the local store, no network). Set to 1 only when you
# deliberately want to fetch from a real bucket (needs `uv sync --extra s3`). Real
# genomics data on cloud stores is where PHI lives, so this never auto-arms.
PIPEGUARD_S3_LIVE=

# Target S3 bucket for the artifact store (when PIPEGUARD_S3_LIVE is armed). Leave blank
# offline; a blank resolves to an "unconfigured" placeholder that degrades to local.
PIPEGUARD_S3_BUCKET=

# Optional key prefix under the bucket; a run stages from s3://<bucket>/<prefix>/<run_id>/.
# Leave blank to stage from s3://<bucket>/<run_id>/.
PIPEGUARD_S3_PREFIX=

# AWS credentials + region are read by boto3 from the STANDARD environment/instance chain
# (this adapter never reads, holds, or logs them). Set these only when PIPEGUARD_S3_LIVE is
# armed; never commit real values. Example:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
