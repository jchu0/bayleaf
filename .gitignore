# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.python-version

# Virtual environments
.venv/
venv/
env/

# Environment / secrets
.env
.env.*
!.env.example
*.pem
credentials.json

# Testing / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# Jupyter
.ipynb_checkpoints/

# ML artifacts / data
*.ckpt
*.pt
*.pth
*.h5
*.onnx
wandb/
mlruns/
data/raw/
data/processed/
models/
outputs/

# Real GIAB HG002 downloads — fetched by scripts/fetch_giab_hg002.py, NEVER committed.
# The reproducible record is the committed manifest (scripts/giab_hg002_manifest.json);
# the bytes (VCF/BED/BAM/index) live here and stay out of git (CLAUDE.md Data-handling 1).
data/real-giab/

# Alignment artifacts must NEVER be committed ANYWHERE in the tree (data-handling guardrail):
# raw reads + indexes are large and often PHI-adjacent. A belt-and-suspenders guard beyond the
# data/ dirs above (a stray HG002.*.bam.bai has appeared at the repo root before).
*.bam
*.bai
*.cram
*.crai

# Bulk synthetic volume — dozens of contrived runs generated on demand by
# `python -m bayleaf.synthetic bulk` for scale testing. Regenerable, never committed;
# the committed record is the CLI + one representative run (data/mock_run_scale_30/).
data/synthetic_bulk/

# Demo/run artifacts — regenerated by `make emit-ledger` / `make rebuild-db`, never committed.
run.events.jsonl
*.sqlite

# In-app feedback telemetry (W12) — append-only local sinks (JSONL / SQLite), never committed.
feedback.events.jsonl
feedback.sqlite

# Pipeline Builder saved graphs (ADR-0014) — local product-state sinks (JSONL / SQLite; the
# .sqlite is already covered by *.sqlite above), never committed.
pipeline_graphs.jsonl
pipeline_graphs.sqlite

# Review-queue tickets (HITL, ADR-0010) — local product-state sinks (JSONL / SQLite; the .sqlite
# is already covered by *.sqlite above), never committed (they carry operator ids). The .tmp glob
# catches the atomic-rewrite temp file if a crash leaves one behind.
review_tickets.jsonl
review_tickets.jsonl.tmp
review_tickets.sqlite
# Settings/config-authoring override drafts (T-051) — product state, never committed.
settings_overrides.jsonl
settings_overrides.jsonl.tmp
settings_overrides.sqlite

# Agent-layer off-gate sinks (2026-07-13) — local product state, never committed (.sqlite already
# covered by *.sqlite above; .tmp catches the atomic-rewrite temp file).
chat_sessions.jsonl
chat_sessions.jsonl.tmp
agent_bindings.jsonl
agent_output_cache.jsonl

# Nextflow run artifacts (ADR-0003) — the generated pipeline TEXT under pipelines/ is committed;
# its execution outputs are not. `nextflow run` writes these into the CWD it runs from.
.nextflow/
.nextflow.log*
work/
pipelines/**/results/
.nf-runs/

# De-identified share/report egress events (ADR-0018 D3) — the pluggable DATA_EXPORTED audit sink
# (api/share_store.py; jsonl/sqlite/postgres). Carries run ids + who exported, so local-only, never
# committed (the .sqlite is already covered by *.sqlite above).
share.events.jsonl

# Node (in case of a web frontend)
node_modules/
.next/

# IDE / editor — JetBrains (IntelliJ IDEA Ultimate, PyCharm, etc.)
.idea/
*.iml
*.ipr
*.iws
.idea_modules/
out/
cmake-build-*/
# VS Code
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Claude Code local settings
.claude/settings.local.json
# Machine-specific dev-server config (absolute venv path); see README to run the app
.claude/launch.json
# Background-agent scratch (git worktrees + agent outputs) — never committed
.claude/worktrees/

# Design-prototype strays — the canonical package lives in docs/design/frontend/.
# Guard the repo root against re-extracting the design zip here (F25).
/bayleaf.html
/source/
/briefs/
/handoffs/

# Real-GIAB end-to-end run output (derived from git-ignored reads; local E2E test).
# Ignore the run's contents but COMMIT its NOTE.md — the honesty disclosure (chr20 downsample,
# arbitrary smoke panel, no clinical claim) should travel with the repo even though the reads never do.
data/RUN-*-GIAB-*/*
!data/RUN-*-GIAB-*/NOTE.md

# Submitted-run outputs from POST /api/runs (real-giab-derived, local; regenerate via Submit)
data/RUN-SUBMIT-*/
