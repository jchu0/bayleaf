# Real GIAB HG002 downloads — fetched by scripts/fetch_giab_hg002.py, NEVER committed.
# The reproducible record is the committed manifest (scripts/giab_hg002_manifest.json);
# the bytes (VCF/BED/BAM/index) live here and stay out of git (CLAUDE.md Data-handling 1).
data/real-giab/

# Bulk synthetic volume — dozens of contrived runs generated on demand by
# `python -m pipeguard.synthetic bulk` for scale testing. Regenerable, never committed;
# the committed record is the CLI + one representative run (data/mock_run_scale_30/).
data/synthetic_bulk/

# Demo/run artifacts — regenerated by `make emit-ledger` / `make rebuild-db`, never committed.
run.events.jsonl
*.sqlite

# In-app feedback telemetry (W12) — append-only local sinks (JSONL / SQLite), never committed.
feedback.events.jsonl
feedback.sqlite

# Pipeline Builder saved graphs (ADR-0014) — local product-state sinks (JSONL / SQLite; the
# .sqlite is already covered by *.sqlite above), never committed.
pipeline_graphs.jsonl
pipeline_graphs.sqlite

# Node (in case of a web frontend)
node_modules/
.next/

# IDE / editor — JetBrains (IntelliJ IDEA Ultimate, PyCharm, etc.)
